---
// MT Valves & Fittings UAE — BaseLayout
// Provides shared <head>, SEO meta, OpenGraph and language/RTL handling.
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  lang?: 'en' | 'ar';
  image?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title = 'MT Valves & Fittings UAE — Industrial Valves · Dubai Hub',
  description = 'Source industrial valves and fittings in the UAE from MT’s Dubai hub. HVAC, district cooling, oil & gas, water. ISO 5211, geared, electric and pneumatic.',
  lang = 'en',
  image = '/logo.svg',
  canonical,
  noindex = false,
} = Astro.props;

const dir = lang === 'ar' ? 'rtl' : 'ltr';
const siteUrl = Astro.site?.toString() ?? 'https://mtme.ae/';
const pageUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
---
<!DOCTYPE html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={pageUrl} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MT Valves & Fittings UAE" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={new URL(image, siteUrl).toString()} />
    <meta property="og:locale" content={lang === 'ar' ? 'ar_AE' : 'en_AE'} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />

    {/* hreflang */}
    <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname.replace(/^\/ar/, ''), siteUrl).toString()} />
    <link rel="alternate" hreflang="ar" href={new URL('/ar' + Astro.url.pathname.replace(/^\/ar/, ''), siteUrl).toString()} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    {/* Favicon */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-paper text-ink font-sans antialiased">
    <Header lang={lang} />
    <main id="main" class="min-h-[60vh]">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
