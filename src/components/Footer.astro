---
// MT Valves & Fittings UAE — Footer
// Catalogue column only renders when the catalogue module is enabled.
import { site, features } from '../config/site';

interface Props { lang?: 'en' | 'ar'; }
const { lang = 'en' } = Astro.props;
const year = new Date().getFullYear();

const t = lang === 'ar'
  ? { tagline: 'الوصول إلى صمامات موثوقة في دبي', rights: 'جميع الحقوق محفوظة', contact: 'اتصل', articles: 'المقالات', cat: 'الكتالوج' }
  : { tagline: 'Source trusted industrial valves from Dubai', rights: 'All rights reserved', contact: 'Contact', articles: 'Articles', cat: 'Catalogue' };
---
<footer class="w-full bg-ink text-paper mt-24">
  <div class="max-w-editorial mx-auto px-6 lg:px-10 py-16 grid gap-10 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="font-display text-3xl font-bold tracking-wider2">MT</div>
      <p class="mt-4 text-mist max-w-md">{t.tagline}</p>
    </div>

    <div>
      <div class="eyebrow text-mist">Dubai · UAE</div>
      <address class="not-italic mt-3 text-mist text-sm leading-relaxed">
        {site.address.line1}<br />
        {site.address.line2}<br />
        <a href={'mailto:' + site.email} class="underline hover:text-signal">{site.email}</a>
      </address>
    </div>

    <div>
      <div class="eyebrow text-mist">Site</div>
      <ul class="mt-3 space-y-2 text-mist text-sm">
        {features.articles && (<li><a href="/articles/" class="hover:text-signal">{t.articles}</a></li>)}
        {features.contact && (<li><a href="/contact/" class="hover:text-signal">{t.contact}</a></li>)}
        {features.catalogue && (<>
          <li><a href="/catalogue/" class="hover:text-signal">Butterfly</a></li>
          <li><a href="/catalogue/" class="hover:text-signal">Ball</a></li>
          <li><a href="/catalogue/" class="hover:text-signal">Gate / Globe / Check</a></li>
        </>)}
      </ul>
    </div>
  </div>

  <div class="border-t border-graphite">
    <div class="max-w-editorial mx-auto px-6 lg:px-10 py-6 text-xs text-steel flex justify-between">
      <span>© {year} {site.name}</span>
      <span>{t.rights}</span>
    </div>
  </div>
</footer>
