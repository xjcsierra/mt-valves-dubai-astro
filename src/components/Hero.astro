---
// MT Valves & Fittings UAE — Hero (Home)
interface Props { lang?: 'en' | 'ar'; }
const { lang = 'en' } = Astro.props;
const t = lang === 'ar'
  ? {
      eyebrow: 'صمامات صناعية · دبي',
      h1: 'الحصول على الصمامات والتركيبات من مركز MT في دبي.',
      sub: 'تصنيع إسباني · توزيع خليجي.',
      cta1: 'استعرض الكتالوج',
      cta2: 'اطلب عرض أسعار'
    }
  : {
      eyebrow: 'Industrial valves · Dubai',
      h1: 'Source valves and fittings from MT’s Dubai hub.',
      sub: 'Spanish manufacturing · GCC distribution.',
      cta1: 'Browse catalogue',
      cta2: 'Request a quote'
    };
const base = lang === 'ar' ? '/ar' : '';
---
<section class="relative bg-paper border-b border-mist">
  <div class="max-w-editorial mx-auto px-6 lg:px-10 py-20 lg:py-28 grid lg:grid-cols-12 gap-10 items-end">
    <div class="lg:col-span-8">
      <div class="eyebrow text-accent">{t.eyebrow}</div>
      <h1 class="mt-4 font-display font-bold text-5xl lg:text-7xl leading-[0.95] tracking-tight text-ink max-w-4xl">
        {t.h1}
      </h1>
      <p class="mt-6 text-graphite text-xl max-w-2xl">{t.sub}</p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href={base + '/catalogue/'} class="inline-flex items-center gap-2 bg-ink text-paper px-6 py-3 text-sm uppercase tracking-wider2 hover:bg-accent transition">
          {t.cta1} <span aria-hidden="true">→</span>
        </a>
        <a href={base + '/contact/'} class="inline-flex items-center gap-2 border border-ink text-ink px-6 py-3 text-sm uppercase tracking-wider2 hover:bg-ink hover:text-paper transition">
          {t.cta2}
        </a>
      </div>
    </div>
    <div class="lg:col-span-4 hidden lg:block">
      <div class="aspect-[3/4] bg-mist border border-mist relative overflow-hidden">
        <div class="absolute inset-0 grid place-items-center">
          <span class="font-display text-9xl text-steel/40 select-none">MT</span>
        </div>
      </div>
    </div>
  </div>
</section>
