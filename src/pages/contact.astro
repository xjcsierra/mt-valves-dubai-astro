---
// MT Valves & Fittings UAE — Contact page (Phase 1)
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
---
<BaseLayout
  title="Contact — MT Valves & Fittings UAE"
  description="Get in touch with MT Valves & Fittings in Dubai. Email, address and contact form for UAE and GCC enquiries."
  lang="en"
>
  <section class="max-w-editorial mx-auto px-6 lg:px-10 py-20">
    <div class="eyebrow text-accent">Contact</div>
    <h1 class="mt-3 font-display font-bold text-4xl lg:text-6xl tracking-tight">Talk to our Dubai team.</h1>
    <p class="mt-6 text-lg text-graphite max-w-2xl">
      Tell us about your project — valve type, size range, sector and quantities. We typically reply within one business day.
    </p>

    <div class="mt-12 grid lg:grid-cols-12 gap-12">
      <aside class="lg:col-span-5 space-y-6 text-lg">
        <div>
          <div class="eyebrow text-steel">Office</div>
          <p class="mt-1">{site.address.line1}<br />{site.address.line2}</p>
        </div>
        <div>
          <div class="eyebrow text-steel">Email</div>
          <p class="mt-1"><a href={'mailto:' + site.email} class="underline hover:text-accent">{site.email}</a></p>
        </div>
        <div>
          <div class="eyebrow text-steel">Hours</div>
          <p class="mt-1 text-graphite">Sun – Thu · 09:00 – 18:00 (GST)</p>
        </div>
      </aside>

      <form class="lg:col-span-7 grid gap-4" method="post" action={'mailto:' + site.email} enctype="text/plain">
        <label class="grid gap-1 text-sm">
          <span class="eyebrow text-steel">Name</span>
          <input required name="Name" type="text" class="border border-mist px-4 py-3 bg-paper focus:outline-none focus:border-accent" />
        </label>
        <label class="grid gap-1 text-sm">
          <span class="eyebrow text-steel">Company</span>
          <input name="Company" type="text" class="border border-mist px-4 py-3 bg-paper focus:outline-none focus:border-accent" />
        </label>
        <label class="grid gap-1 text-sm">
          <span class="eyebrow text-steel">Email</span>
          <input required name="Email" type="email" class="border border-mist px-4 py-3 bg-paper focus:outline-none focus:border-accent" />
        </label>
        <label class="grid gap-1 text-sm">
          <span class="eyebrow text-steel">Message</span>
          <textarea required name="Message" rows="6" class="border border-mist px-4 py-3 bg-paper focus:outline-none focus:border-accent"></textarea>
        </label>
        <button type="submit" class="justify-self-start mt-2 bg-ink text-paper px-6 py-3 text-sm uppercase tracking-wider2 hover:bg-accent transition">
          Send message →
        </button>
        <p class="text-xs text-steel">This form opens your email client. For a hosted form (Formspree / Web3Forms / Cloudflare Workers) we can switch later.</p>
      </form>
    </div>
  </section>
</BaseLayout>
