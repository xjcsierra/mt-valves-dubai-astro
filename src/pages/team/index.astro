---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Team Area · MT Valves & Fittings';
const description = 'Private consultation area for MT Valves & Fittings team members.';
---

<BaseLayout title={title} description={description} noindex={true}>
  <section class="bg-mt-navy text-white">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:py-24">
      <p class="text-sm uppercase tracking-widest text-mt-sky">Internal</p>
      <h1 class="mt-3 text-3xl sm:text-5xl font-bold">Team Consultation Area</h1>
      <p class="mt-4 max-w-2xl text-mt-sky-200/90">
        Private workspace for MT Valves &amp; Fittings staff. Catalogue browser, technical datasheets,
        pricing notes and internal documentation will live here.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:py-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-mt-navy">Catalogue (224 PDPs)</h2>
        <p class="mt-2 text-sm text-slate-600">
          Full searchable catalogue with datasheets. Pending v22 database import.
        </p>
        <span class="mt-4 inline-block rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700">Coming soon</span>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-mt-navy">Technical Datasheets</h2>
        <p class="mt-2 text-sm text-slate-600">PDF library for valves, fittings and accessories.</p>
        <span class="mt-4 inline-block rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700">Coming soon</span>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-mt-navy">Internal Notes</h2>
        <p class="mt-2 text-sm text-slate-600">Pricing guidelines, stock notes, supplier contacts.</p>
        <span class="mt-4 inline-block rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700">Coming soon</span>
      </article>
    </div>

    <div class="mt-12 rounded-2xl border border-slate-200 bg-slate-50 p-6 text-sm text-slate-600">
      <p><strong>Access restricted.</strong> This area is protected by HTTP Basic Authentication enforced at the edge by Cloudflare Pages. If you reached this page you have been authenticated as a team member.</p>
    </div>
  </section>
</BaseLayout>
