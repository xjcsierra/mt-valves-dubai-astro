---
// MT Valves & Fittings UAE — Landing (Phase 1)
// Sections render conditionally based on feature flags in src/config/site.ts.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { site, features } from '../config/site';
---
<BaseLayout
  title="MT Valves & Fittings UAE — Industrial Valves · Dubai Hub"
  description="MT Valves & Fittings — Dubai-based supplier of industrial valves and fittings for HVAC, district cooling, water and oil & gas across the UAE and GCC."
  lang="en"
>
  <Hero lang="en" />

  {/* About / Sectors */}
  <section class="max-w-editorial mx-auto px-6 lg:px-10 py-20">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <div class="eyebrow text-accent">About MT in Dubai</div>
        <h2 class="mt-3 font-display font-semibold text-3xl lg:text-5xl tracking-tight">
          A Spanish valve manufacturer with a hub in the UAE.
        </h2>
      </div>
      <div class="lg:col-span-7 text-lg text-graphite leading-relaxed space-y-5">
        <p>
          MT Valves & Fittings designs and manufactures industrial valves in Spain and operates a
          dedicated logistics and commercial hub in Dubai’s Jebel Ali Free Zone to serve the
          Gulf region.
        </p>
        <p>
          We supply contractors, EPC firms and distributors working in HVAC, district cooling,
          water networks, oil & gas and marine applications.
        </p>
      </div>
    </div>
  </section>

  {/* Latest articles (Phase 1 — placeholders) */}
  {features.articles && (
    <section class="bg-mist/40 border-y border-mist">
      <div class="max-w-editorial mx-auto px-6 lg:px-10 py-20">
        <div class="flex items-end justify-between flex-wrap gap-4">
          <div>
            <div class="eyebrow text-accent">Articles</div>
            <h2 class="mt-3 font-display font-semibold text-3xl lg:text-4xl tracking-tight">From the desk</h2>
          </div>
          <a href="/articles/" class="text-sm uppercase tracking-wider2 text-graphite hover:text-accent">All articles →</a>
        </div>
        <div class="mt-10 grid md:grid-cols-3 gap-8">
          <article class="bg-paper border border-mist p-6">
            <div class="eyebrow text-steel">UAE · Launch</div>
            <h3 class="mt-3 font-display font-semibold text-xl leading-snug">MT opens its Dubai hub for GCC distribution</h3>
            <p class="mt-3 text-sm text-graphite">A new chapter for MT in the region, with local stock and expert advisory.</p>
          </article>
          <article class="bg-paper border border-mist p-6">
            <div class="eyebrow text-steel">HVAC · Technical</div>
            <h3 class="mt-3 font-display font-semibold text-xl leading-snug">Choosing the right butterfly valve for district cooling</h3>
            <p class="mt-3 text-sm text-graphite">Torque, sealing and material guidance for typical Gulf installations.</p>
          </article>
          <article class="bg-paper border border-mist p-6">
            <div class="eyebrow text-steel">Standards</div>
            <h3 class="mt-3 font-display font-semibold text-xl leading-snug">ISO 5211 mounting interfaces — a quick reference</h3>
            <p class="mt-3 text-sm text-graphite">A short reference table for F03 to F25 actuator mounting.</p>
          </article>
        </div>
      </div>
    </section>
  )}

  {/* Contact — Phase 1 */}
  {features.contact && (
    <section class="max-w-editorial mx-auto px-6 lg:px-10 py-20">
      <div class="grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5">
          <div class="eyebrow text-accent">Contact</div>
          <h2 class="mt-3 font-display font-semibold text-3xl lg:text-5xl tracking-tight">Talk to our Dubai team.</h2>
          <p class="mt-6 text-graphite text-lg">Tell us about your project. We typically reply within one business day.</p>
        </div>
        <div class="lg:col-span-7 space-y-4 text-lg">
          <div>
            <div class="eyebrow text-steel">Office</div>
            <p class="mt-1">{site.address.line1}<br />{site.address.line2}</p>
          </div>
          <div>
            <div class="eyebrow text-steel">Email</div>
            <p class="mt-1"><a href={'mailto:' + site.email} class="underline hover:text-accent">{site.email}</a></p>
          </div>
          <a href="/contact/" class="inline-flex items-center gap-2 bg-ink text-paper px-6 py-3 text-sm uppercase tracking-wider2 hover:bg-accent transition">
            Send a message →
          </a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
