---
import BaseLayout from '../layouts/BaseLayout.astro';
import { features, site } from '../config/site';

const title = 'MT Valves & Fittings · Now open in the UAE';
const description = 'MT Valves & Fittings has opened its public hub in Dubai. Industrial valves, fittings and flow-control solutions for the Middle East market.';
---
<BaseLayout title={title} description={description}>
  <!-- Announcement bar -->
  <div class="bg-mt-navy text-white">
    <div class="mx-auto max-w-7xl px-4 py-2 text-center text-sm">
      🎉 <span class="font-semibold">We are now open in the UAE.</span>
      <span class="hidden sm:inline opacity-90"> Dubai hub serving the Middle East market.</span>
    </div>
  </div>

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-mt-navy via-mt-navy to-mt-blue text-white">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:py-28">
      <p class="text-sm uppercase tracking-widest text-mt-sky">Public opening · Dubai, UAE</p>
      <h1 class="mt-3 text-4xl sm:text-6xl font-bold leading-tight max-w-4xl">
        MT Valves &amp; Fittings is now open in the United Arab Emirates.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-mt-sky-200/90">
        After more than three decades supplying industrial valves and fittings across Europe,
        MT brings its full catalogue and engineering support to the Middle East from its new
        Jebel Ali Free Zone hub in Dubai.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact" class="inline-flex items-center rounded-xl bg-white px-5 py-3 text-mt-navy font-semibold hover:bg-mt-sky-200 transition">Request a quote</a>
        {features.articles && (
          <a href="/articles" class="inline-flex items-center rounded-xl border border-white/40 px-5 py-3 text-white font-semibold hover:bg-white/10 transition">Read our articles</a>
        )}
      </div>
    </div>
  </section>

  <!-- What we do -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:py-20">
    <div class="max-w-3xl">
      <h2 class="text-2xl sm:text-3xl font-bold text-mt-navy">Industrial flow-control for the Gulf</h2>
      <p class="mt-3 text-slate-600">
        Ball, gate, globe and check valves. Pipe fittings, flanges and accessories.
        Stock available in Dubai and direct factory shipments for project quantities.
      </p>
    </div>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-mt-navy">Valves</h3>
        <p class="mt-2 text-sm text-slate-600">Ball, gate, globe, check and butterfly valves in carbon and stainless steel.</p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-mt-navy">Fittings &amp; Flanges</h3>
        <p class="mt-2 text-sm text-slate-600">Elbows, tees, reducers, caps and flanges. Multiple pressure classes.</p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-mt-navy">Engineering support</h3>
        <p class="mt-2 text-sm text-slate-600">Datasheets, material certificates and project assistance from our Dubai team.</p>
      </article>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-slate-50 border-t border-slate-200">
    <div class="mx-auto max-w-7xl px-4 py-16 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-mt-navy">Talk to our Dubai team</h2>
      <p class="mt-3 text-slate-600">Jebel Ali Free Zone · Dubai, UAE · {site.email}</p>
      <a href="/contact" class="mt-6 inline-flex items-center rounded-xl bg-mt-navy px-5 py-3 text-white font-semibold hover:bg-mt-blue transition">Contact us</a>
    </div>
  </section>
</BaseLayout>
