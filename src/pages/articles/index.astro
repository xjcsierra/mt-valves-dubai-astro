---
// MT Valves & Fittings UAE — Articles index (Phase 1, static placeholders)
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = [
  {
    slug: 'mt-opens-dubai-hub',
    eyebrow: 'UAE · Launch',
    title: 'MT opens its Dubai hub for GCC distribution',
    excerpt: 'A new chapter for MT in the region, with local stock and expert advisory in Jebel Ali Free Zone.'
  },
  {
    slug: 'butterfly-valves-district-cooling',
    eyebrow: 'HVAC · Technical',
    title: 'Choosing the right butterfly valve for district cooling',
    excerpt: 'Torque, sealing and material guidance for typical Gulf installations.'
  },
  {
    slug: 'iso-5211-mounting-reference',
    eyebrow: 'Standards',
    title: 'ISO 5211 mounting interfaces — a quick reference',
    excerpt: 'A short reference table for F03 to F25 actuator mounting flanges.'
  }
];
---
<BaseLayout
  title="Articles — MT Valves & Fittings UAE"
  description="Technical notes, launch news and engineering references from MT Valves & Fittings in Dubai."
  lang="en"
>
  <section class="max-w-editorial mx-auto px-6 lg:px-10 py-20">
    <div class="eyebrow text-accent">Articles</div>
    <h1 class="mt-3 font-display font-bold text-4xl lg:text-6xl tracking-tight">From the desk</h1>
    <p class="mt-6 text-graphite text-lg max-w-2xl">
      Short, practical notes on industrial valves, GCC projects and engineering standards.
    </p>

    <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {articles.map((a) => (
        <a href={'/articles/' + a.slug + '/'} class="block bg-paper border border-mist p-6 hover:border-accent transition">
          <div class="eyebrow text-steel">{a.eyebrow}</div>
          <h2 class="mt-3 font-display font-semibold text-xl leading-snug">{a.title}</h2>
          <p class="mt-3 text-sm text-graphite">{a.excerpt}</p>
          <span class="mt-4 inline-block text-xs uppercase tracking-wider2 text-accent">Read →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
