---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'News & insights — MT Middle East';
const description = 'News, press releases and technical articles from MT Middle East — covering valves, fittings, certifications, HVAC and the GCC construction market.';

const articles = [
  {
    slug: 'mt-opens-dubai-hub',
    eyebrow: 'Press release · April 2026',
    title: 'MT opens regional hub in Dubai to serve the UAE and GCC markets',
    excerpt: 'A new logistics and commercial centre in Jumeirah Lakes Towers marks MT\'s direct entry into the UAE and the wider Gulf market — with 48-hour dispatch and documentation aligned to local tender requirements.'
  },
  {
    slug: 'mt-at-big-5-global-2025',
    eyebrow: 'News · November 2025',
    title: 'MT at Big 5 Global 2025: three days in Dubai that reshaped our Middle East plans',
    excerpt: 'The largest construction event in the Arab world was not on our calendar as a fair to exhibit. It was on our calendar as a market to listen to.'
  },
  {
    slug: 'valves-for-gulf-construction-projects',
    eyebrow: 'Technical · Specification guide',
    title: 'Valves for construction projects in the Gulf: what the GCC market actually requires',
    excerpt: 'Specifying valves for a project in the UAE or Saudi Arabia is not the same as specifying for Europe. Climate, regulation and tender documentation impose specific criteria.'
  },
  {
    slug: 'hvac-in-the-gulf',
    eyebrow: 'Technical · HVAC',
    title: 'HVAC in the Gulf: where the right valve is the difference between a project that works and one that fails',
    excerpt: 'Air conditioning accounts for 60–70% of building electricity consumption in the GCC. HVAC systems in the region are large, complex and unforgiving of poor specification.'
  },
  {
    slug: '14-international-certifications',
    eyebrow: 'Quality · Certifications',
    title: '14 international certifications: how MT\'s approvals open doors in 50 markets',
    excerpt: 'In the industrial sector, a certification is not just a document. It is the difference between entering a tender or not. A practical guide to MT\'s certification portfolio.'
  },
  {
    slug: 'industry-references',
    eyebrow: 'Editorial · Resources',
    title: 'International references worth following: the publications, portals and events that shape our sector',
    excerpt: 'A curated selection of specialist media, industry portals and reference bodies for valve and fitting professionals — covering technical guidance and regional construction trends.'
  }
];
---
<BaseLayout title={title} description={description} lang="en-GB">
  <section class="max-w-editorial mx-auto px-6 lg:px-10 py-20">

    <div class="eyebrow text-accent">News &amp; insights</div>

    <h1 class="mt-3 font-display font-bold text-4xl lg:text-6xl tracking-tight leading-tight">
      News, press and technical articles
    </h1>

    <p class="mt-6 text-xl text-graphite max-w-3xl leading-relaxed">
      Updates from MT Middle East, technical guides for the GCC market, and editorial pieces from our team in Dubai and Pallejà (Barcelona).
    </p>

    <div class="mt-16 space-y-12">
      {articles.map((article) => (
        <a href={`/articles/${article.slug}`} class="block group border-t border-mist pt-8 hover:border-accent transition">
          <div class="eyebrow text-steel group-hover:text-accent transition">{article.eyebrow}</div>
          <h2 class="mt-3 font-display font-semibold text-2xl lg:text-3xl text-ink group-hover:text-accent transition leading-tight">
            {article.title}
          </h2>
          <p class="mt-4 text-graphite max-w-3xl leading-relaxed">
            {article.excerpt}
          </p>
          <div class="mt-4 eyebrow text-accent">Read article &rarr;</div>
        </a>
      ))}
    </div>

  </section>
</BaseLayout>
